# ─────────────────────────────────────────────
#  SoundWave — Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Get these from developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# Must match exactly what you set in your Spotify app's Redirect URIs
SPOTIFY_REDIRECT_URI=http://localhost:3000/callback

# Random secret string for session encryption (make this long and random)
SESSION_SECRET=change_this_to_a_long_random_string_abc123xyz

# Port to run the server on
PORT=3000
